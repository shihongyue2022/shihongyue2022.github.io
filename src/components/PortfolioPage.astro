---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from './ProjectCard.astro';
import CertificateCard from './CertificateCard.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localePaths, ui, type Locale } from '../i18n';
import type { ResumeData } from '../types';

interface Props {
  locale: Locale;
  data: ResumeData;
}

const { locale, data } = Astro.props;
const { profile, skills, experience, education, projects, certificates } = data;
const t = ui[locale];
const github = profile.socials.find((item) => item.label.toLowerCase() === 'github');
const emailReady = profile.email && !profile.email.startsWith('your-');
const encodedEmail = encodeURIComponent(profile.email);
const navTargets = ['about', 'experience', 'projects', 'certificates', 'contact'];
---

<BaseLayout title={`${profile.name} · ${profile.role}`} description={profile.summary} locale={locale} page="home">
  <a class="skip-link" href="#main">{t.skip}</a>
  <header class="site-header">
    <a class="brand" href="#top" aria-label={t.backHome}>
      <span class="brand-mark">SH</span><span class="brand-name">{profile.shortName}</span>
    </a>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="site-nav">{t.menu}</button>
    <nav id="site-nav" class="site-nav" aria-label={t.navigation}>
      {t.nav.map((label, index) => <a href={`#${navTargets[index]}`}>{label}</a>)}
    </nav>
    <div class="header-actions">
      <LanguageSwitcher locale={locale} page="home" />
      <button class="icon-button theme-toggle" type="button" aria-label={t.theme} title={t.theme}>◐</button>
      <a class="button button-small" href={localePaths[locale].resume}>{t.printResume}</a>
    </div>
  </header>

  <main id="main">
    <section id="top" class="hero section-shell">
      <div class="hero-copy reveal">
        <p class="eyebrow"><span class="status-dot"></span>{profile.availability}</p>
        <h1>{t.hello}<br /><span>{profile.name}{t.nameSuffix}</span></h1>
        <p class="hero-role">{profile.role}</p><p class="hero-summary">{profile.summary}</p>
        <div class="hero-actions"><a class="button" href="#projects">{t.viewProjects} <span aria-hidden="true">↘</span></a><a class="text-link" href="#contact">{t.contactMe} <span aria-hidden="true">→</span></a></div>
      </div>
      <aside class="hero-card reveal" aria-label={t.overview}>
        <div class="avatar-wrap"><img class="avatar" src={profile.avatar} alt={`${profile.name} avatar`} /><span class="avatar-ring" aria-hidden="true"></span></div>
        <dl class="quick-facts">
          <div><dt>{t.facts[0]}</dt><dd>{profile.location}</dd></div><div><dt>{t.facts[1]}</dt><dd>{profile.focus}</dd></div><div><dt>{t.facts[2]}</dt><dd>{profile.workMode}</dd></div>
        </dl>
        <div class="social-links">{profile.socials.map((item) => <a href={item.url} target="_blank" rel="noreferrer">{item.label} ↗</a>)}</div>
      </aside>
    </section>

    <section id="about" class="section section-shell">
      <div class="section-heading reveal"><p class="section-index">{t.aboutIndex}</p><h2>{t.aboutTitle}</h2></div>
      <div class="about-grid">
        <p class="lead reveal">{profile.about}</p>
        <div class="skills-list reveal" aria-label={t.skills}>
          {skills.map((group) => <section class="skill-group"><h3>{group.category}</h3><div class="skill-tags">{group.items.map((item) => <span class="tag">{item}</span>)}</div></section>)}
        </div>
      </div>
    </section>

    <section id="experience" class="section section-shell">
      <div class="section-heading reveal"><p class="section-index">{t.experienceIndex}</p><h2>{t.experienceTitle}</h2></div>
      <div class="experience-layout">
        <div><h3 class="subheading">{t.work}</h3><div class="timeline">
          {experience.map((item) => <article class="timeline-item reveal"><p class="timeline-meta">{item.period} · {item.location}</p><h3>{item.role}</h3><h4>{item.company}</h4><p>{item.description}</p>{item.highlights.length > 0 && <ul>{item.highlights.map((point) => <li>{point}</li>)}</ul>}</article>)}
        </div></div>
        <div><h3 class="subheading">{t.education}</h3><div class="education-list">
          {education.map((item) => <article class="education-card reveal"><p class="period">{item.period}</p><h3>{item.school}</h3><h4>{item.degree}</h4><p>{item.description}</p></article>)}
        </div></div>
      </div>
    </section>

    <section id="projects" class="section section-shell">
      <div class="section-heading heading-row reveal"><div><p class="section-index">{t.projectsIndex}</p><h2>{t.projectsTitle}</h2></div><p class="heading-note">{t.projectsNote}</p></div>
      <div class="projects-grid">{projects.map((project, index) => <ProjectCard project={project} index={index} sourceLabel={t.source} demoLabel={t.demo} />)}</div>
    </section>

    <section id="certificates" class="section section-shell">
      <div class="section-heading heading-row reveal"><div><p class="section-index">{t.certificationsIndex}</p><h2>{t.certificationsTitle}</h2></div><p class="heading-note">{t.certificationsNote}</p></div>
      {certificates.length > 0
        ? <div class="certificates-grid">{certificates.map((certificate) => <CertificateCard certificate={certificate} credentialLabel={t.credentialId} />)}</div>
        : <div class="empty-state"><span class="empty-icon">＋</span><p>{t.emptyCertTitle}</p><small>{t.emptyCertHelp}</small></div>}
    </section>

    <section id="contact" class="contact section-shell reveal">
      <p class="section-index">{t.contactIndex}</p><h2>{t.contactTitle}<br />{t.contactLine}</h2><p>{profile.contactText}</p>
      <div class="contact-actions">
        {emailReady
          ? <button class="button button-light" id="email-dialog-open" type="button">{t.sendEmail} ↗</button>
          : <a class="button button-light" href={github?.url}>{t.viewGitHub} ↗</a>}
        {github && emailReady && <a class="text-link text-link-light" href={github.url} target="_blank" rel="noreferrer">GitHub ↗</a>}
      </div>
      {emailReady && (
        <dialog id="email-dialog" class="contact-dialog" aria-labelledby="email-dialog-title">
          <div class="contact-dialog-inner">
            <div class="contact-dialog-header">
              <div><h3 id="email-dialog-title">{t.emailOptionsTitle}</h3><p>{t.emailOptionsText}</p></div>
              <button class="dialog-close" type="button" data-dialog-close aria-label={t.close}>×</button>
            </div>
            <div class="email-options">
              <a class="email-option" href={`mailto:${profile.email}`}>{t.defaultMail}<span>↗</span></a>
              <a class="email-option" href={`https://mail.google.com/mail/?view=cm&fs=1&to=${encodedEmail}`} target="_blank" rel="noreferrer">{t.gmail}<span>↗</span></a>
              <a class="email-option" href={`https://outlook.live.com/mail/0/deeplink/compose?to=${encodedEmail}`} target="_blank" rel="noreferrer">{t.outlook}<span>↗</span></a>
              <button class="email-option" type="button" data-copy-email={profile.email} data-copy-label={t.copyEmail} data-copied-label={t.emailCopied}>{t.copyEmail}<span>⧉</span></button>
            </div>
          </div>
        </dialog>
      )}
    </section>
  </main>

  <footer class="site-footer section-shell"><p>© {new Date().getFullYear()} {profile.name}</p><p>{t.footer}</p></footer>
  <script>
    const themeButton = document.querySelector<HTMLButtonElement>('.theme-toggle');
    themeButton?.addEventListener('click', () => {
      const theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = theme;
      localStorage.setItem('resume-theme', theme);
    });
    const menuButton = document.querySelector<HTMLButtonElement>('.menu-button');
    const nav = document.querySelector<HTMLElement>('.site-nav');
    menuButton?.addEventListener('click', () => {
      const open = nav?.classList.toggle('open') ?? false;
      menuButton.setAttribute('aria-expanded', String(open));
    });
    nav?.addEventListener('click', () => {
      nav.classList.remove('open');
      menuButton?.setAttribute('aria-expanded', 'false');
    });
    const emailDialog = document.querySelector<HTMLDialogElement>('#email-dialog');
    document.querySelector('#email-dialog-open')?.addEventListener('click', () => emailDialog?.showModal());
    emailDialog?.querySelector('[data-dialog-close]')?.addEventListener('click', () => emailDialog.close());
    emailDialog?.addEventListener('click', (event) => {
      if (event.target === emailDialog) emailDialog.close();
    });
    emailDialog?.querySelector<HTMLButtonElement>('[data-copy-email]')?.addEventListener('click', async (event) => {
      const button = event.currentTarget as HTMLButtonElement;
      const email = button.dataset.copyEmail || '';
      let copied = false;
      try {
        await navigator.clipboard.writeText(email);
        copied = true;
      } catch {
        window.prompt(button.dataset.copyLabel || 'Copy email', email);
      }
      if (!copied) return;
      const original = button.childNodes[0]?.textContent || '';
      if (button.childNodes[0]) button.childNodes[0].textContent = button.dataset.copiedLabel || original;
      window.setTimeout(() => { if (button.childNodes[0]) button.childNodes[0].textContent = original; }, 1800);
    });
  </script>
</BaseLayout>
