---
import type { Project } from '../types';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<article class="project-card reveal">
  <span class="project-number">PROJECT / {String(index + 1).padStart(2, '0')}</span>
  <h3>{project.name}</h3>
  <p>{project.description}</p>
  {project.impact && <p class="project-impact">{project.impact}</p>}
  <div class="project-footer">
    <div class="skill-tags">
      {project.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <div class="project-links">
      {project.repoUrl && <a href={project.repoUrl} target="_blank" rel="noreferrer">Source ↗</a>}
      {project.demoUrl && <a href={project.demoUrl} target="_blank" rel="noreferrer">Demo ↗</a>}
    </div>
  </div>
</article>
