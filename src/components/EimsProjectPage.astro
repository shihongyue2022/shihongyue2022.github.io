---
import BaseLayout from '../layouts/BaseLayout.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localePaths, type Locale } from '../i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;

const copy = {
  en: {
    back: 'Back to portfolio', label: 'CASE STUDY / WEB APPLICATION',
    title: 'Equipment Inspection Management System',
    intro: 'A role-based operations platform for recording field inspections and giving administrators a clear, real-time view of equipment, assignments, and inspection history.',
    source: 'View source', note: 'Static portfolio preview — no real accounts or operational data are used.',
    overview: 'Project overview', overviewText: 'EIMS turns equipment inspection work that is often fragmented across paper and spreadsheets into a traceable web workflow. Engineers record results in the field while administrators manage equipment, accounts, assignments, and audit history.',
    features: 'Core capabilities', featureItems: ['Role-based authentication and authorization', 'Equipment, account, and inspection CRUD workflows', 'Inspection schedules, notifications, and recycle bin', 'Audit logs and soft deletion for traceability'],
    architecture: 'Architecture', layers: [['Presentation', 'Jinja templates · responsive UI'], ['Application', 'Flask views · DTO · service logic'], ['Data access', 'DAO · transactions · migrations'], ['Persistence', 'MySQL / TiDB Cloud']],
    quality: 'Engineering & quality', qualityText: 'The project uses a modular Flask structure, schema migration scripts, Docker configuration, and pytest-based view and integration tests. Database credentials remain outside the repository through environment variables.',
    preview: 'Interface preview', dashboard: 'Operations dashboard', healthy: 'Operational', equipment: 'Equipment', inspections: 'Inspections', completion: 'Completion', recent: 'Recent inspections', status: 'Status', complete: 'Complete', pending: 'Pending',
    stack: 'Technology', next: 'Explore the implementation on GitHub'
  },
  zh: {
    back: '返回作品集', label: '项目案例 / WEB 应用', title: '设备点检管理系统',
    intro: '面向现场工程师与管理员的角色权限管理平台，用于登记点检结果，并集中查看设备、负责人及点检历史。',
    source: '查看源代码', note: '静态作品集预览——不使用真实账号或业务数据。',
    overview: '项目概览', overviewText: 'EIMS 将分散在纸张和表格中的设备点检工作转化为可追踪的 Web 流程。工程师可登记现场结果，管理员可管理设备、账号、任务分配和审计记录。',
    features: '核心功能', featureItems: ['基于角色的认证与权限控制', '设备、账号与点检 CRUD 流程', '点检计划、通知与回收站', '通过审计日志和软删除保证可追踪性'],
    architecture: '系统架构', layers: [['表现层', 'Jinja 模板 · 响应式界面'], ['应用层', 'Flask 视图 · DTO · 业务逻辑'], ['数据访问层', 'DAO · 事务 · 数据库迁移'], ['持久层', 'MySQL / TiDB Cloud']],
    quality: '工程实践与质量', qualityText: '项目采用模块化 Flask 结构，包含数据库迁移脚本、Docker 配置，以及基于 pytest 的视图和集成测试。数据库凭据通过环境变量管理，不进入代码仓库。',
    preview: '界面预览', dashboard: '运营仪表盘', healthy: '运行正常', equipment: '设备', inspections: '点检记录', completion: '完成率', recent: '最近点检', status: '状态', complete: '已完成', pending: '待处理',
    stack: '技术栈', next: '前往 GitHub 查看实现'
  },
  ja: {
    back: 'ポートフォリオへ戻る', label: 'CASE STUDY / WEBアプリケーション', title: '設備点検管理システム',
    intro: 'フィールドエンジニアが点検結果を登録し、管理者が設備・担当者・点検履歴を一元管理できるロールベースの業務プラットフォームです。',
    source: 'ソースコードを見る', note: '静的なポートフォリオ表示です。実在するアカウントや業務データは使用していません。',
    overview: 'プロジェクト概要', overviewText: 'EIMSは、紙や表計算に分散しがちな設備点検を追跡可能なWebワークフローへ変換します。現場では点検結果を登録し、管理者は設備、アカウント、担当割当、監査履歴を管理できます。',
    features: '主な機能', featureItems: ['ロールベース認証・認可', '設備・アカウント・点検のCRUD', '点検予定・通知・ごみ箱', '監査ログと論理削除による追跡性'],
    architecture: 'アーキテクチャ', layers: [['プレゼンテーション', 'Jinjaテンプレート · レスポンシブUI'], ['アプリケーション', 'Flask View · DTO · 業務ロジック'], ['データアクセス', 'DAO · トランザクション · マイグレーション'], ['永続化', 'MySQL / TiDB Cloud']],
    quality: '品質と開発プラクティス', qualityText: 'モジュール化されたFlask構成、DBマイグレーション、Docker設定、pytestによるView・結合テストを整備しています。DB認証情報は環境変数で管理し、リポジトリには保存しません。',
    preview: '画面プレビュー', dashboard: '運用ダッシュボード', healthy: '正常稼働', equipment: '設備', inspections: '点検記録', completion: '完了率', recent: '最近の点検', status: '状態', complete: '完了', pending: '対応待ち',
    stack: '技術スタック', next: 'GitHubで実装を見る'
  }
}[locale];

const repo = 'https://github.com/shihongyue2022/Equipment-Inspection-Management-System-EIMS-';
---

<BaseLayout title={`${copy.title} | Shihong Yue`} description={copy.intro} locale={locale} page="project" className="project-detail-page">
  <header class="case-header">
    <a class="case-back" href={localePaths[locale].home}>← {copy.back}</a>
    <div class="case-actions"><LanguageSwitcher locale={locale} page="project" /><button class="icon-button theme-toggle" type="button" aria-label="Toggle theme">◐</button></div>
  </header>
  <main>
    <section class="case-hero case-shell">
      <p class="eyebrow">{copy.label}</p><h1>{copy.title}</h1><p class="case-lead">{copy.intro}</p>
      <div class="case-cta"><a class="button" href={repo} target="_blank" rel="noreferrer">{copy.source} ↗</a><span>{copy.note}</span></div>
    </section>
    <section class="product-preview case-shell" aria-label={copy.preview}>
      <div class="preview-body">
        <aside>
          <div class="app-brand"><span class="hamburger">☰</span><strong><i>ET</i> ECH</strong><span class="bell">♢</span></div>
          <nav><span class="active">◉ ダッシュボード</span><span>☷ 設備一覧</span><span>▣ 点検記録登録</span><span>♙ アカウント管理</span><span>♲ ゴミ箱</span></nav>
          <div class="mock-user"><span>● 山田 太郎</span><small>管理者</small><button>⇥ ログアウト</button></div>
        </aside>
        <div class="preview-main">
          <div class="dashboard-bar"><h2>ダッシュボード</h2><label>拠点 <span>全拠点⌄</span></label></div>
          <div class="metrics">
            <article class="metric-blue"><small>全設備数</small><div><i>▱</i><strong>248</strong></div></article>
            <article class="metric-orange"><small>担当未登録数</small><div><i>♙</i><strong>12</strong></div></article>
            <article class="metric-red"><small>点検期限超過</small><div><i>!</i><strong>8</strong></div></article>
            <article class="metric-yellow"><small>点検期限間近</small><div><i>◷</i><strong>21</strong></div></article>
            <article class="metric-purple"><small>要修理数</small><div><i>⌁</i><strong>5</strong></div></article>
          </div>
          <div class="analysis-panels">
            <article class="chart-card"><h3>▥ エリア別異常件数</h3><div class="bars"><span style="--h:54%"><b>東北</b></span><span style="--h:82%"><b>関東</b></span><span style="--h:38%"><b>中部</b></span><span style="--h:66%"><b>関西</b></span><span style="--h:28%"><b>九州</b></span></div></article>
            <article class="load-card"><h3>☷ 担当者別負荷</h3><div class="load-head"><span>担当者</span><span>担当拠点</span><span>担当数</span><span>期限超過</span></div><div><span>佐藤 花子</span><span>東京</span><b>42</b><em>2</em></div><div><span>鈴木 一郎</span><span>大阪</span><b>37</b><em>1</em></div><div><span>田中 美咲</span><span>名古屋</span><b>31</b><em>0</em></div></article>
          </div>
        </div>
      </div>
    </section>
    <section class="case-grid case-shell"><article class="case-card overview-card"><p class="section-index">01</p><h2>{copy.overview}</h2><p>{copy.overviewText}</p></article><article class="case-card features-card"><p class="section-index">02</p><h2>{copy.features}</h2><ul>{copy.featureItems.map(item => <li>{item}</li>)}</ul></article></section>
    <section class="architecture case-shell"><p class="section-index">03 / {copy.architecture}</p><div class="layer-list">{copy.layers.map(([name, detail], index) => <article><span>0{index + 1}</span><strong>{name}</strong><p>{detail}</p></article>)}</div></section>
    <section class="case-grid case-shell quality-section"><article class="case-card quality-card"><p class="section-index">04</p><h2>{copy.quality}</h2><p>{copy.qualityText}</p></article></section>
    <section class="stack-band"><div class="case-shell"><p class="section-index">{copy.stack}</p><div class="stack-list">{['Python', 'Flask', 'MySQL / TiDB', 'Docker', 'pytest', 'Jinja'].map(item => <span>{item}</span>)}</div><a href={repo} target="_blank" rel="noreferrer">{copy.next} ↗</a></div></section>
  </main>
  <script>document.querySelector('.theme-toggle')?.addEventListener('click', () => { const theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark'; document.documentElement.dataset.theme = theme; localStorage.setItem('resume-theme', theme); });</script>
</BaseLayout>

<style>
  .case-shell{width:min(1100px,calc(100% - 3rem));margin-inline:auto}.case-header{display:flex;align-items:center;justify-content:space-between;min-height:76px;padding:0 max(1.5rem,calc((100vw - 1100px)/2));border-bottom:1px solid var(--line)}.case-back{font-weight:600;text-decoration:none}.case-actions{display:flex;gap:.7rem;align-items:center}.case-hero{padding-block:clamp(5rem,10vw,9rem)}.case-hero h1{max-width:950px;margin:0;font-size:clamp(3.2rem,8vw,7rem);line-height:.95;letter-spacing:-.065em}.case-lead{max-width:760px;margin:2rem 0;color:var(--muted);font-size:clamp(1.1rem,2vw,1.35rem)}.case-cta{display:flex;align-items:center;gap:1.5rem}.case-cta span{max-width:420px;color:var(--muted);font-size:.82rem}.product-preview{overflow:hidden;margin-bottom:8rem;border:1px solid var(--line);border-radius:1.5rem;background:#f5f6f8;color:#343a40;box-shadow:var(--shadow);font-family:Arial,'Noto Sans JP',sans-serif}.preview-body{display:grid;grid-template-columns:190px 1fr;min-height:540px}.preview-body aside{display:flex;flex-direction:column;background:#0d6efd;color:#fff}.app-brand{display:flex;align-items:center;gap:.6rem;height:62px;padding:0 1rem;border-bottom:1px solid rgb(255 255 255 / 25%)}.app-brand strong{flex:1;font-size:1.1rem;letter-spacing:.04em}.app-brand strong i{color:#9fc5ff;font-style:normal}.hamburger,.bell{font-size:.85rem}.preview-body nav{display:flex;flex-direction:column;gap:.25rem;padding:1rem .75rem}.preview-body nav span{padding:.65rem .7rem;border-radius:.35rem;font-size:.78rem}.preview-body nav .active{background:rgb(255 255 255 / 22%)}.mock-user{display:grid;grid-template-columns:1fr auto;gap:.4rem;margin-top:auto;padding:1rem;border-top:1px solid rgb(255 255 255 / 25%);font-size:.72rem}.mock-user small{padding:.12rem .35rem;border-radius:.25rem;background:#ffc107;color:#343a40}.mock-user button{grid-column:1/-1;padding:.35rem;border:1px solid rgb(255 255 255 / 65%);border-radius:.25rem;background:transparent;color:#fff}.preview-main{min-width:0;padding:0 1.2rem 1.2rem}.dashboard-bar{display:flex;align-items:center;justify-content:space-between;height:62px;margin-bottom:1rem;border-bottom:1px solid #dee2e6;background:#fff}.dashboard-bar h2{margin:0;font-size:1.15rem}.dashboard-bar label{color:#6c757d;font-size:.7rem}.dashboard-bar label span{display:inline-block;margin-left:.4rem;padding:.35rem 1.8rem .35rem .5rem;border:1px solid #ced4da;border-radius:.25rem;background:#fff;color:#495057}.metrics{display:grid;grid-template-columns:repeat(5,1fr);gap:.65rem}.metrics article{padding:.75rem;border-radius:.35rem;background:#fff;box-shadow:0 2px 8px rgb(0 0 0 / 7%);text-align:center}.metrics small{display:block;color:#6c757d;font-size:.65rem}.metrics article div{display:flex;align-items:center;justify-content:center;gap:.4rem;margin-top:.5rem}.metrics strong{font-size:1.8rem}.metrics i{display:grid;place-items:center;width:32px;height:32px;border-radius:50%;font-style:normal;font-weight:700}.metric-blue{color:#0d6efd}.metric-blue i{background:#e7f1ff}.metric-orange{color:#fd7e14}.metric-orange i{background:#fff1e6}.metric-red{color:#dc3545}.metric-red i{background:#fce8ea}.metric-yellow{color:#d19b00}.metric-yellow i{background:#fff7d6}.metric-purple{color:#6f42c1}.metric-purple i{background:#f0e9fb}.analysis-panels{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-top:1rem}.analysis-panels article{overflow:hidden;min-height:250px;border-radius:.35rem;background:#fff;box-shadow:0 2px 8px rgb(0 0 0 / 7%)}.analysis-panels h3{margin:0;padding:.85rem 1rem;border-bottom:1px solid #e9ecef;color:#343a40;font-size:.82rem}.bars{display:flex;align-items:end;justify-content:space-around;height:180px;padding:1rem 1rem 2rem}.bars span{position:relative;width:11%;height:var(--h);border-radius:.2rem .2rem 0 0;background:#4b91f1}.bars b{position:absolute;top:calc(100% + .45rem);left:50%;color:#6c757d;font-size:.55rem;font-weight:400;transform:translateX(-50%)}.load-card>div{display:grid;grid-template-columns:1.4fr 1fr .7fr .8fr;gap:.3rem;padding:.65rem 1rem;border-bottom:1px solid #edf0f2;font-size:.62rem}.load-card .load-head{background:#f8f9fa;color:#6c757d;font-weight:700}.load-card b,.load-card em{text-align:center}.load-card em{color:#dc3545;font-style:normal;font-weight:700}.case-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding-block:6rem;border-top:1px solid var(--line)}.case-card{position:relative;overflow:hidden;min-height:28rem;padding:clamp(2rem,5vw,3.5rem);border:1px solid var(--line);border-radius:calc(var(--radius) + .35rem);box-shadow:var(--shadow)}.case-card::after{content:'';position:absolute;right:-4rem;bottom:-5rem;width:12rem;height:12rem;border:1px solid currentColor;border-radius:50%;opacity:.12}.overview-card{background:var(--ink);color:var(--bg)}.case-grid .overview-card .section-index,.case-grid .overview-card>p{color:color-mix(in srgb,var(--bg) 72%,transparent)}.features-card{background:var(--accent);color:#17231d}.case-grid .features-card .section-index,.case-grid .features-card li{color:#3d4a42}.features-card li::marker{color:#17231d}.quality-section{grid-template-columns:1fr}.quality-card{min-height:0;background:linear-gradient(135deg,var(--surface) 0 72%,color-mix(in srgb,var(--accent) 55%,var(--surface)) 72%);color:var(--ink)}.quality-card>p{max-width:760px}.case-grid h2{margin:.5rem 0 1.5rem;font-size:clamp(2rem,4vw,3.5rem);line-height:1.05;letter-spacing:-.045em}.case-grid p,.case-grid li{color:var(--muted)}.case-grid ul{display:grid;gap:.75rem;padding-left:1.2rem}.architecture{padding-block:6rem;border-top:1px solid var(--line)}.layer-list{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.layer-list article{padding:1.4rem;border:1px solid var(--line);border-radius:var(--radius);background:var(--surface)}.layer-list span{color:var(--muted);font-size:.75rem}.layer-list strong{display:block;margin:2rem 0 .5rem}.layer-list p{margin:0;color:var(--muted);font-size:.85rem}.stack-band{padding-block:6rem;background:var(--dark);color:#f4f1eb}.stack-band .section-index{color:#aab4ad}.stack-list{display:flex;flex-wrap:wrap;gap:.75rem;margin:0 0 3rem}.stack-list span{padding:.65rem 1rem;border:1px solid #455049;border-radius:999px}.stack-band a{font-size:clamp(1.4rem,3vw,2.5rem);font-weight:700;text-underline-offset:.4rem}@media(max-width:760px){.case-hero h1{font-size:clamp(2.8rem,14vw,4.7rem)}.case-cta{align-items:flex-start;flex-direction:column}.preview-body{grid-template-columns:1fr;min-height:0}.preview-body aside{display:none}.preview-main{padding:0 .7rem .7rem}.metrics{grid-template-columns:repeat(2,1fr)}.analysis-panels{grid-template-columns:1fr}.chart-card{display:none}.case-grid{grid-template-columns:1fr}.case-card{min-height:0}.layer-list{grid-template-columns:1fr 1fr}}@media(max-width:480px){.layer-list{grid-template-columns:1fr}.language-switcher{display:none}.metrics{grid-template-columns:1fr 1fr}.dashboard-bar label{display:none}}
</style>
