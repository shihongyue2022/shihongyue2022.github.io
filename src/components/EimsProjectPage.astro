---
import BaseLayout from '../layouts/BaseLayout.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localePaths, type Locale } from '../i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;

const copy = {
  en: {
    back: 'Back to portfolio', label: 'CASE STUDY / WEB APPLICATION',
    title: 'Equipment Inspection Management System',
    intro: 'A role-based operations platform for recording field inspections and giving administrators a clear, real-time view of equipment, assignments, and inspection history.',
    source: 'View source', note: 'Static portfolio preview — no real accounts or operational data are used.',
    overview: 'Project overview', overviewText: 'EIMS turns equipment inspection work that is often fragmented across paper and spreadsheets into a traceable web workflow. Engineers record results in the field while administrators manage equipment, accounts, assignments, and audit history.',
    features: 'Core capabilities', featureItems: ['Role-based authentication and authorization', 'Equipment, account, and inspection CRUD workflows', 'Inspection schedules, notifications, and recycle bin', 'Audit logs and soft deletion for traceability'],
    architecture: 'Architecture', layers: [['Presentation', 'Jinja templates · responsive UI'], ['Application', 'Flask views · DTO · service logic'], ['Data access', 'DAO · transactions · migrations'], ['Persistence', 'MySQL / TiDB Cloud']],
    quality: 'Engineering & quality', qualityText: 'The project uses a modular Flask structure, schema migration scripts, Docker configuration, and pytest-based view and integration tests. Database credentials remain outside the repository through environment variables.',
    preview: 'Interface preview', dashboard: 'Operations dashboard', healthy: 'Operational', equipment: 'Equipment', inspections: 'Inspections', completion: 'Completion', recent: 'Recent inspections', status: 'Status', complete: 'Complete', pending: 'Pending',
    privacy: 'Why this demo is static', privacyText: 'GitHub Pages cannot run the Python backend or database. This page therefore presents the product safely without exposing credentials, employee accounts, or inspection records.',
    stack: 'Technology', next: 'Explore the implementation on GitHub'
  },
  zh: {
    back: '返回作品集', label: '项目案例 / WEB 应用', title: '设备点检管理系统',
    intro: '面向现场工程师与管理员的角色权限管理平台，用于登记点检结果，并集中查看设备、负责人及点检历史。',
    source: '查看源代码', note: '静态作品集预览——不使用真实账号或业务数据。',
    overview: '项目概览', overviewText: 'EIMS 将分散在纸张和表格中的设备点检工作转化为可追踪的 Web 流程。工程师可登记现场结果，管理员可管理设备、账号、任务分配和审计记录。',
    features: '核心功能', featureItems: ['基于角色的认证与权限控制', '设备、账号与点检 CRUD 流程', '点检计划、通知与回收站', '通过审计日志和软删除保证可追踪性'],
    architecture: '系统架构', layers: [['表现层', 'Jinja 模板 · 响应式界面'], ['应用层', 'Flask 视图 · DTO · 业务逻辑'], ['数据访问层', 'DAO · 事务 · 数据库迁移'], ['持久层', 'MySQL / TiDB Cloud']],
    quality: '工程实践与质量', qualityText: '项目采用模块化 Flask 结构，包含数据库迁移脚本、Docker 配置，以及基于 pytest 的视图和集成测试。数据库凭据通过环境变量管理，不进入代码仓库。',
    preview: '界面预览', dashboard: '运营仪表盘', healthy: '运行正常', equipment: '设备', inspections: '点检记录', completion: '完成率', recent: '最近点检', status: '状态', complete: '已完成', pending: '待处理',
    privacy: '为什么使用静态演示', privacyText: 'GitHub Pages 无法运行 Python 后端和数据库，因此本页面以安全方式展示产品，不暴露凭据、员工账号或点检记录。',
    stack: '技术栈', next: '前往 GitHub 查看实现'
  },
  ja: {
    back: 'ポートフォリオへ戻る', label: 'CASE STUDY / WEBアプリケーション', title: '設備点検管理システム',
    intro: 'フィールドエンジニアが点検結果を登録し、管理者が設備・担当者・点検履歴を一元管理できるロールベースの業務プラットフォームです。',
    source: 'ソースコードを見る', note: '静的なポートフォリオ表示です。実在するアカウントや業務データは使用していません。',
    overview: 'プロジェクト概要', overviewText: 'EIMSは、紙や表計算に分散しがちな設備点検を追跡可能なWebワークフローへ変換します。現場では点検結果を登録し、管理者は設備、アカウント、担当割当、監査履歴を管理できます。',
    features: '主な機能', featureItems: ['ロールベース認証・認可', '設備・アカウント・点検のCRUD', '点検予定・通知・ごみ箱', '監査ログと論理削除による追跡性'],
    architecture: 'アーキテクチャ', layers: [['プレゼンテーション', 'Jinjaテンプレート · レスポンシブUI'], ['アプリケーション', 'Flask View · DTO · 業務ロジック'], ['データアクセス', 'DAO · トランザクション · マイグレーション'], ['永続化', 'MySQL / TiDB Cloud']],
    quality: '品質と開発プラクティス', qualityText: 'モジュール化されたFlask構成、DBマイグレーション、Docker設定、pytestによるView・結合テストを整備しています。DB認証情報は環境変数で管理し、リポジトリには保存しません。',
    preview: '画面プレビュー', dashboard: '運用ダッシュボード', healthy: '正常稼働', equipment: '設備', inspections: '点検記録', completion: '完了率', recent: '最近の点検', status: '状態', complete: '完了', pending: '対応待ち',
    privacy: '静的デモである理由', privacyText: 'GitHub PagesではPythonバックエンドやデータベースを実行できません。このページでは認証情報、従業員アカウント、点検記録を公開せず安全にプロダクトを紹介します。',
    stack: '技術スタック', next: 'GitHubで実装を見る'
  }
}[locale];

const repo = 'https://github.com/shihongyue2022/Equipment-Inspection-Management-System-EIMS-';
---

<BaseLayout title={`${copy.title} | Shihong Yue`} description={copy.intro} locale={locale} page="project" className="project-detail-page">
  <header class="case-header">
    <a class="case-back" href={localePaths[locale].home}>← {copy.back}</a>
    <div class="case-actions"><LanguageSwitcher locale={locale} page="project" /><button class="icon-button theme-toggle" type="button" aria-label="Toggle theme">◐</button></div>
  </header>
  <main>
    <section class="case-hero case-shell">
      <p class="eyebrow">{copy.label}</p><h1>{copy.title}</h1><p class="case-lead">{copy.intro}</p>
      <div class="case-cta"><a class="button" href={repo} target="_blank" rel="noreferrer">{copy.source} ↗</a><span>{copy.note}</span></div>
    </section>
    <section class="product-preview case-shell" aria-label={copy.preview}>
      <div class="preview-top"><strong>EIMS</strong><span>{copy.dashboard}</span><small>● {copy.healthy}</small></div>
      <div class="preview-body"><aside><span class="active">▦ {copy.dashboard}</span><span>◇ {copy.equipment}</span><span>✓ {copy.inspections}</span></aside><div class="preview-main">
        <h2>{copy.dashboard}</h2><div class="metrics"><article><small>{copy.equipment}</small><strong>248</strong><i>+12</i></article><article><small>{copy.inspections}</small><strong>1,842</strong><i>+8.4%</i></article><article><small>{copy.completion}</small><strong>96.2%</strong><i>+2.1%</i></article></div>
        <div class="mock-table"><strong>{copy.recent}</strong><div><span>EQ-0248</span><span>2026-07-08</span><b>{copy.complete}</b></div><div><span>EQ-0193</span><span>2026-07-08</span><em>{copy.pending}</em></div><div><span>EQ-0171</span><span>2026-07-07</span><b>{copy.complete}</b></div></div>
      </div></div>
    </section>
    <section class="case-grid case-shell"><article><p class="section-index">01</p><h2>{copy.overview}</h2><p>{copy.overviewText}</p></article><article><p class="section-index">02</p><h2>{copy.features}</h2><ul>{copy.featureItems.map(item => <li>{item}</li>)}</ul></article></section>
    <section class="architecture case-shell"><p class="section-index">03 / {copy.architecture}</p><div class="layer-list">{copy.layers.map(([name, detail], index) => <article><span>0{index + 1}</span><strong>{name}</strong><p>{detail}</p></article>)}</div></section>
    <section class="case-grid case-shell"><article><p class="section-index">04</p><h2>{copy.quality}</h2><p>{copy.qualityText}</p></article><article class="privacy-card"><p class="section-index">05</p><h2>{copy.privacy}</h2><p>{copy.privacyText}</p></article></section>
    <section class="stack-band"><div class="case-shell"><p class="section-index">{copy.stack}</p><div class="stack-list">{['Python', 'Flask', 'MySQL / TiDB', 'Docker', 'pytest', 'Jinja'].map(item => <span>{item}</span>)}</div><a href={repo} target="_blank" rel="noreferrer">{copy.next} ↗</a></div></section>
  </main>
  <script>document.querySelector('.theme-toggle')?.addEventListener('click', () => { const theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark'; document.documentElement.dataset.theme = theme; localStorage.setItem('resume-theme', theme); });</script>
</BaseLayout>

<style>
  .case-shell{width:min(1100px,calc(100% - 3rem));margin-inline:auto}.case-header{display:flex;align-items:center;justify-content:space-between;min-height:76px;padding:0 max(1.5rem,calc((100vw - 1100px)/2));border-bottom:1px solid var(--line)}.case-back{font-weight:600;text-decoration:none}.case-actions{display:flex;gap:.7rem;align-items:center}.case-hero{padding-block:clamp(5rem,10vw,9rem)}.case-hero h1{max-width:950px;margin:0;font-size:clamp(3.2rem,8vw,7rem);line-height:.95;letter-spacing:-.065em}.case-lead{max-width:760px;margin:2rem 0;color:var(--muted);font-size:clamp(1.1rem,2vw,1.35rem)}.case-cta{display:flex;align-items:center;gap:1.5rem}.case-cta span{max-width:420px;color:var(--muted);font-size:.82rem}.product-preview{overflow:hidden;margin-bottom:8rem;border:1px solid var(--line);border-radius:1.5rem;background:#eef2ef;color:#17231d;box-shadow:var(--shadow)}.preview-top{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:1rem 1.3rem;border-bottom:1px solid #d6ddd8;background:#fff}.preview-top small{text-align:right;color:#38834a}.preview-body{display:grid;grid-template-columns:180px 1fr;min-height:500px}.preview-body aside{display:flex;flex-direction:column;gap:.55rem;padding:1.5rem;background:#17231d;color:#aebbb4}.preview-body aside span{padding:.65rem;border-radius:.5rem}.preview-body aside .active{background:#d6ff64;color:#17231d}.preview-main{padding:2rem}.preview-main h2{margin:0 0 1.5rem}.metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.metrics article,.mock-table{padding:1.2rem;border-radius:1rem;background:#fff}.metrics small{display:block;color:#68716c}.metrics strong{display:block;margin:.5rem 0;font-size:2rem}.metrics i{color:#38834a;font-style:normal;font-size:.8rem}.mock-table{margin-top:1rem}.mock-table div{display:grid;grid-template-columns:1fr 1fr 1fr;padding:.9rem 0;border-bottom:1px solid #e1e5e2}.mock-table b{color:#38834a}.mock-table em{color:#a36d00;font-style:normal;font-weight:700}.case-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(3rem,8vw,8rem);padding-block:6rem;border-top:1px solid var(--line)}.case-grid h2{margin:.5rem 0 1.5rem;font-size:clamp(2rem,4vw,3.5rem);line-height:1.05;letter-spacing:-.045em}.case-grid p,.case-grid li{color:var(--muted)}.case-grid ul{display:grid;gap:.75rem;padding-left:1.2rem}.architecture{padding-block:6rem;border-top:1px solid var(--line)}.layer-list{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.layer-list article{padding:1.4rem;border:1px solid var(--line);border-radius:var(--radius);background:var(--surface)}.layer-list span{color:var(--muted);font-size:.75rem}.layer-list strong{display:block;margin:2rem 0 .5rem}.layer-list p{margin:0;color:var(--muted);font-size:.85rem}.privacy-card{padding:2rem;border-radius:var(--radius);background:var(--accent);color:#17231d}.privacy-card p{color:#3e4b43}.stack-band{padding-block:6rem;background:var(--dark);color:#f4f1eb}.stack-band .section-index{color:#aab4ad}.stack-list{display:flex;flex-wrap:wrap;gap:.75rem;margin:0 0 3rem}.stack-list span{padding:.65rem 1rem;border:1px solid #455049;border-radius:999px}.stack-band a{font-size:clamp(1.4rem,3vw,2.5rem);font-weight:700;text-underline-offset:.4rem}@media(max-width:760px){.case-hero h1{font-size:clamp(2.8rem,14vw,4.7rem)}.case-cta{align-items:flex-start;flex-direction:column}.preview-body{grid-template-columns:1fr;min-height:0}.preview-body aside{display:none}.preview-main{padding:1rem}.metrics{grid-template-columns:1fr}.mock-table div{grid-template-columns:1fr 1fr}.mock-table div :nth-child(2){display:none}.case-grid{grid-template-columns:1fr}.layer-list{grid-template-columns:1fr 1fr}.preview-top{grid-template-columns:1fr auto}.preview-top span{display:none}}@media(max-width:480px){.layer-list{grid-template-columns:1fr}.language-switcher{display:none}}
</style>
