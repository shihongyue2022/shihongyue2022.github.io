---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import CertificateCard from '../components/CertificateCard.astro';
import data from '../data/resume.json';
import type { ResumeData } from '../types';

const { profile, skills, experience, education, projects, certificates } = data as ResumeData;
const github = profile.socials.find((item) => item.label.toLowerCase() === 'github');
const emailReady = profile.email && !profile.email.startsWith('your-');
---

<BaseLayout title={`${profile.name} · ${profile.role}`} description={profile.summary}>
  <a class="skip-link" href="#main">跳到主要内容</a>
  <header class="site-header">
    <a class="brand" href="#top" aria-label="返回首页">
      <span class="brand-mark">SH</span><span class="brand-name">{profile.shortName}</span>
    </a>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="site-nav">菜单</button>
    <nav id="site-nav" class="site-nav" aria-label="主导航">
      <a href="#about">关于</a><a href="#experience">经历</a><a href="#projects">项目</a><a href="#certificates">证书</a><a href="#contact">联系</a>
    </nav>
    <div class="header-actions">
      <button class="icon-button theme-toggle" type="button" aria-label="切换深色模式" title="切换主题">◐</button>
      <a class="button button-small" href="/resume/">打印简历</a>
    </div>
  </header>

  <main id="main">
    <section id="top" class="hero section-shell">
      <div class="hero-copy reveal">
        <p class="eyebrow"><span class="status-dot"></span>{profile.availability}</p>
        <h1>你好，我是<br /><span>{profile.name}</span></h1>
        <p class="hero-role">{profile.role}</p><p class="hero-summary">{profile.summary}</p>
        <div class="hero-actions"><a class="button" href="#projects">查看项目 <span aria-hidden="true">↘</span></a><a class="text-link" href="#contact">联系我 <span aria-hidden="true">→</span></a></div>
      </div>
      <aside class="hero-card reveal" aria-label="个人概览">
        <div class="avatar-wrap"><img class="avatar" src={profile.avatar} alt={`${profile.name}的头像`} /><span class="avatar-ring" aria-hidden="true"></span></div>
        <dl class="quick-facts">
          <div><dt>所在地</dt><dd>{profile.location}</dd></div><div><dt>专业方向</dt><dd>{profile.focus}</dd></div><div><dt>工作方式</dt><dd>{profile.workMode}</dd></div>
        </dl>
        <div class="social-links">{profile.socials.map((item) => <a href={item.url} target="_blank" rel="noreferrer">{item.label} ↗</a>)}</div>
      </aside>
    </section>

    <section id="about" class="section section-shell">
      <div class="section-heading reveal"><p class="section-index">01 / 关于</p><h2>我能带来的价值</h2></div>
      <div class="about-grid">
        <p class="lead reveal">{profile.about}</p>
        <div class="skills-list reveal" aria-label="技能列表">
          {skills.map((group) => <section class="skill-group"><h3>{group.category}</h3><div class="skill-tags">{group.items.map((item) => <span class="tag">{item}</span>)}</div></section>)}
        </div>
      </div>
    </section>

    <section id="experience" class="section section-shell">
      <div class="section-heading reveal"><p class="section-index">02 / 经历</p><h2>经验与成长路径</h2></div>
      <div class="experience-layout">
        <div><h3 class="subheading">工作与实践</h3><div class="timeline">
          {experience.map((item) => <article class="timeline-item reveal"><p class="timeline-meta">{item.period} · {item.location}</p><h3>{item.role}</h3><h4>{item.company}</h4><p>{item.description}</p>{item.highlights.length > 0 && <ul>{item.highlights.map((point) => <li>{point}</li>)}</ul>}</article>)}
        </div></div>
        <div><h3 class="subheading">教育经历</h3><div class="education-list">
          {education.map((item) => <article class="education-card reveal"><p class="period">{item.period}</p><h3>{item.school}</h3><h4>{item.degree}</h4><p>{item.description}</p></article>)}
        </div></div>
      </div>
    </section>

    <section id="projects" class="section section-shell">
      <div class="section-heading heading-row reveal"><div><p class="section-index">03 / 项目</p><h2>精选项目作品</h2></div><p class="heading-note">不仅展示做了什么，也说明为什么这样做。</p></div>
      <div class="projects-grid">{projects.map((project, index) => <ProjectCard project={project} index={index} />)}</div>
    </section>

    <section id="certificates" class="section section-shell">
      <div class="section-heading heading-row reveal"><div><p class="section-index">04 / 证书</p><h2>资格证书与认证</h2></div><p class="heading-note">点击证书可前往发证机构验证。</p></div>
      {certificates.length > 0
        ? <div class="certificates-grid">{certificates.map((certificate) => <CertificateCard certificate={certificate} />)}</div>
        : <div class="empty-state"><span class="empty-icon">＋</span><p>证书区域已经准备好</p><small>将图片放入 public/assets/certificates，并在 src/data/resume.json 中添加记录。</small></div>}
    </section>

    <section id="contact" class="contact section-shell reveal">
      <p class="section-index">05 / 联系</p><h2>有合适的机会或有趣的项目？<br />我们聊聊。</h2><p>{profile.contactText}</p>
      <div class="contact-actions"><a class="button button-light" href={emailReady ? `mailto:${profile.email}` : github?.url}>发送邮件 ↗</a>{github && <a class="text-link text-link-light" href={github.url} target="_blank" rel="noreferrer">GitHub ↗</a>}</div>
    </section>
  </main>

  <footer class="site-footer section-shell"><p>© {new Date().getFullYear()} {profile.name}</p><p>Astro 构建 · 托管于 GitHub Pages</p></footer>
  <script>
    const themeButton = document.querySelector<HTMLButtonElement>('.theme-toggle');
    themeButton?.addEventListener('click', () => {
      const theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = theme;
      localStorage.setItem('resume-theme', theme);
    });
    const menuButton = document.querySelector<HTMLButtonElement>('.menu-button');
    const nav = document.querySelector<HTMLElement>('.site-nav');
    menuButton?.addEventListener('click', () => {
      const open = nav?.classList.toggle('open') ?? false;
      menuButton.setAttribute('aria-expanded', String(open));
    });
    nav?.addEventListener('click', () => {
      nav.classList.remove('open');
      menuButton?.setAttribute('aria-expanded', 'false');
    });
  </script>
</BaseLayout>
