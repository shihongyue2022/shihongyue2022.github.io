---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import CertificateCard from '../components/CertificateCard.astro';
import data from '../data/resume.json';
import type { ResumeData } from '../types';

const { profile, skills, experience, education, projects, certificates } = data as ResumeData;
const github = profile.socials.find((item) => item.label.toLowerCase() === 'github');
const emailReady = profile.email && !profile.email.startsWith('your-');
---

<BaseLayout title={`${profile.name} · ${profile.role}`} description={profile.summary}>
  <a class="skip-link" href="#main">Skip to main content</a>
  <header class="site-header">
    <a class="brand" href="#top" aria-label="Back to home">
      <span class="brand-mark">SH</span><span class="brand-name">{profile.shortName}</span>
    </a>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="site-nav">Menu</button>
    <nav id="site-nav" class="site-nav" aria-label="Main navigation">
      <a href="#about">About</a><a href="#experience">Experience</a><a href="#projects">Projects</a><a href="#certificates">Certifications</a><a href="#contact">Contact</a>
    </nav>
    <div class="header-actions">
      <button class="icon-button theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle theme">◐</button>
      <a class="button button-small" href="/resume/">Print Resume</a>
    </div>
  </header>

  <main id="main">
    <section id="top" class="hero section-shell">
      <div class="hero-copy reveal">
        <p class="eyebrow"><span class="status-dot"></span>{profile.availability}</p>
        <h1>Hello, I'm<br /><span>{profile.name}</span></h1>
        <p class="hero-role">{profile.role}</p><p class="hero-summary">{profile.summary}</p>
        <div class="hero-actions"><a class="button" href="#projects">View Projects <span aria-hidden="true">↘</span></a><a class="text-link" href="#contact">Contact Me <span aria-hidden="true">→</span></a></div>
      </div>
      <aside class="hero-card reveal" aria-label="Profile overview">
        <div class="avatar-wrap"><img class="avatar" src={profile.avatar} alt={`${profile.name}'s avatar`} /><span class="avatar-ring" aria-hidden="true"></span></div>
        <dl class="quick-facts">
          <div><dt>Location</dt><dd>{profile.location}</dd></div><div><dt>Focus</dt><dd>{profile.focus}</dd></div><div><dt>Work style</dt><dd>{profile.workMode}</dd></div>
        </dl>
        <div class="social-links">{profile.socials.map((item) => <a href={item.url} target="_blank" rel="noreferrer">{item.label} ↗</a>)}</div>
      </aside>
    </section>

    <section id="about" class="section section-shell">
      <div class="section-heading reveal"><p class="section-index">01 / About</p><h2>What I bring to the table</h2></div>
      <div class="about-grid">
        <p class="lead reveal">{profile.about}</p>
        <div class="skills-list reveal" aria-label="Skills">
          {skills.map((group) => <section class="skill-group"><h3>{group.category}</h3><div class="skill-tags">{group.items.map((item) => <span class="tag">{item}</span>)}</div></section>)}
        </div>
      </div>
    </section>

    <section id="experience" class="section section-shell">
      <div class="section-heading reveal"><p class="section-index">02 / Experience</p><h2>Experience and growth</h2></div>
      <div class="experience-layout">
        <div><h3 class="subheading">Work & Practice</h3><div class="timeline">
          {experience.map((item) => <article class="timeline-item reveal"><p class="timeline-meta">{item.period} · {item.location}</p><h3>{item.role}</h3><h4>{item.company}</h4><p>{item.description}</p>{item.highlights.length > 0 && <ul>{item.highlights.map((point) => <li>{point}</li>)}</ul>}</article>)}
        </div></div>
        <div><h3 class="subheading">Education</h3><div class="education-list">
          {education.map((item) => <article class="education-card reveal"><p class="period">{item.period}</p><h3>{item.school}</h3><h4>{item.degree}</h4><p>{item.description}</p></article>)}
        </div></div>
      </div>
    </section>

    <section id="projects" class="section section-shell">
      <div class="section-heading heading-row reveal"><div><p class="section-index">03 / Projects</p><h2>Selected work</h2></div><p class="heading-note">A closer look at what I built, why it matters, and how I approached it.</p></div>
      <div class="projects-grid">{projects.map((project, index) => <ProjectCard project={project} index={index} />)}</div>
    </section>

    <section id="certificates" class="section section-shell">
      <div class="section-heading heading-row reveal"><div><p class="section-index">04 / Certifications</p><h2>Credentials & certifications</h2></div><p class="heading-note">Select a credential to verify it with the issuing organization.</p></div>
      {certificates.length > 0
        ? <div class="certificates-grid">{certificates.map((certificate) => <CertificateCard certificate={certificate} />)}</div>
        : <div class="empty-state"><span class="empty-icon">＋</span><p>Certification section ready</p><small>Add badge images to public/assets/certificates and records to src/data/resume.json.</small></div>}
    </section>

    <section id="contact" class="contact section-shell reveal">
      <p class="section-index">05 / Contact</p><h2>Have an opportunity or an interesting project?<br />Let's talk.</h2><p>{profile.contactText}</p>
      <div class="contact-actions"><a class="button button-light" href={emailReady ? `mailto:${profile.email}` : github?.url}>{emailReady ? 'Send an Email' : 'View GitHub'} ↗</a>{github && emailReady && <a class="text-link text-link-light" href={github.url} target="_blank" rel="noreferrer">GitHub ↗</a>}</div>
    </section>
  </main>

  <footer class="site-footer section-shell"><p>© {new Date().getFullYear()} {profile.name}</p><p>Built with Astro · Hosted on GitHub Pages</p></footer>
  <script>
    const themeButton = document.querySelector<HTMLButtonElement>('.theme-toggle');
    themeButton?.addEventListener('click', () => {
      const theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = theme;
      localStorage.setItem('resume-theme', theme);
    });
    const menuButton = document.querySelector<HTMLButtonElement>('.menu-button');
    const nav = document.querySelector<HTMLElement>('.site-nav');
    menuButton?.addEventListener('click', () => {
      const open = nav?.classList.toggle('open') ?? false;
      menuButton.setAttribute('aria-expanded', String(open));
    });
    nav?.addEventListener('click', () => {
      nav.classList.remove('open');
      menuButton?.setAttribute('aria-expanded', 'false');
    });
  </script>
</BaseLayout>
